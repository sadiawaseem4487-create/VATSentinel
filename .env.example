# =============================================================================
# VAT Sentinel — environment variables
# Copy to `.env.local` for local development (`npm run dev`).
# On Vercel (demo): add the same keys under Project → Settings → Environment Variables.
# =============================================================================

# --- Supabase (required for API routes) ---
# Project URL (Settings → API). Either line works for server routes; NEXT_PUBLIC_ also exposes URL to the browser if needed.
NEXT_PUBLIC_SUPABASE_URL=
# Optional alias — same value as NEXT_PUBLIC_SUPABASE_URL if you prefer non-public name only:
# SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (chat assistant at /chat, /api/chat) ---
# API key from https://openrouter.ai/keys — either name works:
OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# Optional override (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=

# --- Chat / assistant RAG (optional) ---
# Full-table scan cap for status histogram + claim amount sums (default 100000).
# CHAT_AGGREGATE_MAX_ROWS=100000
# Recent rows included as narrative sample in portfolio overview (10–200, default 75).
# CHAT_OVERVIEW_SAMPLE_SIZE=75

# --- n8n Cloud (HTTPS webhooks; use production URLs on Vercel) ---
# Chain 1: after a submission is saved (POST from /api/submit)
# Must be https://… Production URL from the Webhook node (workflow Active). No quotes.
N8N_WEBHOOK_URL=https://YOUR_INSTANCE.app.n8n.cloud/webhook/vat-claim
# Alias (same meaning as N8N_WEBHOOK_URL — supported for Vercel naming):
# N8N_VAT_Claim_URL=https://YOUR_INSTANCE.app.n8n.cloud/webhook/vat-claim
# Optional: max wait for n8n HTTP response in ms (default 8000). Vercel Hobby ~10s total function time.
# N8N_WEBHOOK_TIMEOUT_MS=8000
# Chain 2: optional — dashboard calls POST /api/n8n/notify-review after saving a decision (PATCH)
N8N_REVIEW_WEBHOOK_URL=https://YOUR_INSTANCE.app.n8n.cloud/webhook/review-case
# N8N_REVIEW_Case_WEBHOOK_URL=https://YOUR_INSTANCE.app.n8n.cloud/webhook/review-case
# Optional: max wait for review webhook HTTP response in ms (default 15000)
# N8N_REVIEW_WEBHOOK_TIMEOUT_MS=15000
# Optional default reviewer email in the review webhook JSON
# N8N_REVIEW_DEFAULT_EMAIL=reviewer@example.com

# =============================================================================
# Notes
# - Local: `.env.local` is gitignored; restart `npm run dev` after changes.
# - Vercel: set variables for Production (and Preview if you use PR previews).
# - NEXT_PUBLIC_VERCEL_ENV is injected at build time on Vercel (see next.config.mjs);
#   locally it stays empty so the UI can show a "Local" label.
# =============================================================================
