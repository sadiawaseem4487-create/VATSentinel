# =============================================================================
# VAT Sentinel — environment variables
# Copy to `.env.local` for local development (`npm run dev`).
# On Vercel (demo): add the same keys under Project → Settings → Environment Variables.
# =============================================================================

# --- Supabase (required for API routes) ---
# Project URL (Settings → API). Either line works for server routes; NEXT_PUBLIC_ also exposes URL to the browser if needed.
NEXT_PUBLIC_SUPABASE_URL=
# Optional alias — same value as NEXT_PUBLIC_SUPABASE_URL if you prefer non-public name only:
# SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (chat assistant) ---
# API key from OpenRouter; used as OPENAI_API_KEY for the OpenAI SDK-compatible client.
OPENAI_API_KEY=
# Optional override (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=

# --- n8n Cloud (HTTPS webhooks; use production URLs on Vercel) ---
# Chain 1: after a submission is saved (POST from /api/submit)
N8N_WEBHOOK_URL=https://YOUR_INSTANCE.app.n8n.cloud/webhook/vat-claim
# Chain 2: optional — when evaluator approves/rejects (/api/submissions/[id] PATCH)
N8N_REVIEW_WEBHOOK_URL=https://YOUR_INSTANCE.app.n8n.cloud/webhook/review-case
# Optional default reviewer email in the review webhook JSON
# N8N_REVIEW_DEFAULT_EMAIL=reviewer@example.com

# =============================================================================
# Notes
# - Local: `.env.local` is gitignored; restart `npm run dev` after changes.
# - Vercel: set variables for Production (and Preview if you use PR previews).
# - NEXT_PUBLIC_VERCEL_ENV is injected at build time on Vercel (see next.config.mjs);
#   locally it stays empty so the UI can show a "Local" label.
# =============================================================================
